# Web (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:8000

# API
DATABASE_URL=sqlite:///./asl_pilot.db
# SUPABASE_JWT_SECRET: leave empty for dev (the API will accept X-User-Id
# from any client). For PRODUCTION, populate with your Supabase project's
# JWT secret (Settings → API → JWT Settings) so the backend verifies
# Bearer tokens and ignores untrusted X-User-Id headers.
SUPABASE_JWT_SECRET=
CORS_ORIGINS=http://localhost:5173
